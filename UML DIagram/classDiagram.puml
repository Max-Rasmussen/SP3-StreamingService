}
class FileHandler <<utility>> {

+ void readFiles(File csvfile)
+ void saveFiles(File csvfile)

+ void parseLogin(ArrayList<String>)

+ void parseMovies(ArrayList<String>)

+ void parseSeries((ArrayList<String>)


}


class UserInput <<utility>>{


+String promptUserString(String message)
+int promptUserInt(String message)

}
class Menu{
+User currentUser

- void printSelectedMedia(ArrayList<Media>)
+ void searchMedia(String input)
+ ArrayList<Media> sortByCategories(Enum category)
